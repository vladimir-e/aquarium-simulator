{
  "name": "aquarium-simulator",
  "version": "0.1.0",
  "description": "Pure-TypeScript aquarium ecosystem simulation engine — water chemistry, nitrogen cycle, livestock, plants, algae, and equipment.",
  "type": "module",
  "packageManager": "npm@11.4.2",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "sideEffects": false,
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "rm -rf dist && tsc -p tsconfig.build.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint 'src/**/*.{ts,tsx}'",
    "lint:fresh": "eslint --no-cache 'src/**/*.{ts,tsx}'",
    "ui": "vite",
    "ui:build": "vite build",
    "prepublishOnly": "npm run build && npm test"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/vladimir-e/aquarium-simulator.git"
  },
  "keywords": [
    "aquarium",
    "fish-tank",
    "simulation",
    "ecosystem",
    "nitrogen-cycle",
    "water-chemistry",
    "biology",
    "typescript"
  ],
  "author": "Vladimir Evdokimov",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/vladimir-e/aquarium-simulator/issues"
  },
  "homepage": "https://github.com/vladimir-e/aquarium-simulator#readme",
  "dependencies": {
    "immer": "^11.1.3"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.0.13",
    "@testing-library/react": "^16.1.0",
    "@types/node": "^25.0.6",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@typescript-eslint/eslint-plugin": "^8.52.0",
    "@typescript-eslint/parser": "^8.52.0",
    "@vitejs/plugin-react": "^4.3.4",
    "@vitest/coverage-v8": "^4.0.17",
    "eslint": "^9.39.2",
    "happy-dom": "^16.2.3",
    "lucide-react": "^0.562.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tailwindcss": "^4.0.13",
    "typescript": "^5.9.3",
    "vite": "^6.0.7",
    "vitest": "^4.0.17",
    "zod": "^4.3.6"
  }
}
